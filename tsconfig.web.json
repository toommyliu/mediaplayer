{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@/*": [
        "./src/renderer/src/*"
      ]
    }
  },
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/App.tsx",
    "src/renderer/src/main.tsx",
    "src/renderer/src/types.ts",
    "src/renderer/src/components/SidebarPanel.tsx",
    "src/renderer/src/components/VideoPlayer.tsx",
    "src/renderer/src/components/settings/**/*.tsx",
    "src/renderer/src/components/ui/button.tsx",
    "src/renderer/src/components/ui/checkbox.tsx",
    "src/renderer/src/components/ui/dialog.tsx",
    "src/renderer/src/components/ui/input.tsx",
    "src/renderer/src/components/ui/kbd.tsx",
    "src/renderer/src/hooks/**/*.ts",
    "src/renderer/src/lib/**/*",
    "src/shared/**/*",
    "src/preload/*.d.ts",
    "src/common/**/*"
  ]
}
